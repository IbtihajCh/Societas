# Auto-detect text files
* text=auto

# Source code
*.py text diff=python
*.ts text diff=typescript
*.tsx text diff=typescript
*.js text diff=javascript
*.json text
*.yaml text
*.yml text
*.md text
*.toml text
*.cfg text
*.ini text

# Documentation
*.md text
*.rst text

# Binary
*.png binary
*.jpg binary
*.ico binary
*.pdf binary
*.docx binary
*.woff2 binary

# GitHub specific
*.gitignore text
*.gitattributes text

# Ensure consistent line endings
* text=auto eol=lf
