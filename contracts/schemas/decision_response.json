{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecisionResponse",
  "description": "AI decision response",
  "type": "object",
  "required": ["selected_action", "confidence", "reasoning"],
  "properties": {
    "selected_action": {
      "type": "string",
      "description": "The action selected by the AI"
    },
    "confidence": {
      "type": "number",
      "description": "Confidence score (0-1)",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string",
      "description": "Explanation of the decision"
    },
    "scores": {
      "type": "object",
      "description": "Scores for each option",
      "additionalProperties": {
        "type": "number"
      }
    }
  }
}
