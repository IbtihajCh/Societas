{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NewsEvent",
  "description": "News event generated by the simulation",
  "type": "object",
  "required": ["id", "tick", "headline", "content", "category"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique news event identifier"
    },
    "tick": {
      "type": "integer",
      "description": "Tick when the event occurred"
    },
    "headline": {
      "type": "string",
      "description": "News headline"
    },
    "content": {
      "type": "string",
      "description": "Full news content"
    },
    "category": {
      "type": "string",
      "enum": ["ECONOMIC", "SOCIAL", "CRIME", "POLITICAL", "GENERAL"],
      "description": "News category"
    },
    "sentiment": {
      "type": "string",
      "enum": ["POSITIVE", "NEGATIVE", "NEUTRAL"],
      "description": "Overall sentiment"
    },
    "related_agents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of agents related to this event"
    }
  }
}
